{
  "name": "zehd",
  "displayName": "zehd",
  "description": "Language support for the zehd programming language",
  "version": "0.1.0",
  "publisher": "zehd",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:zehd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "zehd",
        "aliases": [
          "zehd",
          "Zed"
        ],
        "extensions": [
          ".z"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zehd",
        "scopeName": "source.zehd",
        "path": "./syntaxes/zehd.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "zehd",
      "properties": {
        "zehd.lsp.path": {
          "type": "string",
          "default": "zehd",
          "description": "Path to the zehd binary"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
