{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "zehd",
  "scopeName": "source.zehd",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#interpolated-strings" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#http-methods" },
    { "include": "#special-keywords" },
    { "include": "#type-keywords" },
    { "include": "#constants" },
    { "include": "#time-literals" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zehd",
          "match": "//.*$"
        },
        {
          "name": "comment.block.zehd",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.zehd",
      "begin": "(?<!\\$)\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.zehd",
          "match": "\\\\."
        }
      ]
    },
    "interpolated-strings": {
      "name": "string.interpolated.zehd",
      "begin": "\\$\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.zehd",
          "match": "\\\\."
        },
        {
          "name": "meta.interpolation.zehd",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.zehd" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.zehd" }
          },
          "patterns": [
            { "include": "source.zehd" }
          ]
        }
      ]
    },
    "attributes": {
      "name": "meta.attribute.zehd",
      "begin": "#\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute.begin.zehd" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute.end.zehd" }
      },
      "patterns": [
        {
          "name": "entity.other.attribute-name.zehd",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#constants" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zehd",
          "match": "\\b(if|else|match|for|in|while|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.zehd",
          "match": "\\b(let|const|fn|type|enum)\\b"
        },
        {
          "name": "keyword.control.import.zehd",
          "match": "\\b(import|from)\\b"
        }
      ]
    },
    "http-methods": {
      "name": "keyword.other.http-method.zehd",
      "match": "\\b(get|post|put|patch|delete)\\b"
    },
    "special-keywords": {
      "patterns": [
        {
          "name": "keyword.other.init.zehd",
          "match": "\\b(init|error)\\b"
        },
        {
          "name": "variable.language.self.zehd",
          "match": "\\bself\\b"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "support.type.zehd",
          "match": "\\b(Option|Result)\\b"
        },
        {
          "name": "support.type.enum-variant.zehd",
          "match": "\\b(Ok|Err|Some|None)\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.zehd",
      "match": "\\b(true|false)\\b"
    },
    "time-literals": {
      "name": "constant.numeric.time.zehd",
      "match": "\\b[0-9]+(ms|s|m|h)\\b"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.zehd",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.zehd",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.zehd",
          "match": "=>"
        },
        {
          "name": "keyword.operator.namespace.zehd",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.zehd",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.zehd",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.zehd",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.zehd",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.try.zehd",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.spread.zehd",
          "match": "\\.\\.\\."
        }
      ]
    },
    "function-declaration": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.zehd" },
        "2": { "name": "entity.name.function.zehd" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "entity.name.function.call.zehd" }
      }
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.zehd",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
